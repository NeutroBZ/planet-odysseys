---
// src/pages/[...slug].astro
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllBlogPosts, getBlogPostBySlug, formatBlogDate } from '../data/blog';

export async function getStaticPaths() {
  const posts = await getAllBlogPosts();
  return posts.map(post => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const post = await getBlogPostBySlug(slug!);

if (!post) {
  return Astro.redirect('/404');
}

const allPosts = await getAllBlogPosts();
const relatedPosts = allPosts
  .filter(p => p.slug !== post.slug)
  .filter(p => p.categories?.some(cat => post.categories?.includes(cat)))
  .slice(0, 3);

const { Content } = await Astro.glob('../content/blog/*.md').then(
  modules => modules.find(m => m.frontmatter?.slug === post.slug)
);

const formattedDate = formatBlogDate(post.date);

const readingTime = post.content ? Math.ceil(post.content.split(' ').length / 200) : 5;
---

<BaseLayout 
  title={`${post.title} | Planet Odysseys Blog`}
  description={post.description || `Read about ${post.title} on our travel blog`}
>

<main class="min-h-screen bg-dark">

  <section class="relative h-[70vh] min-h-[600px] flex items-end overflow-hidden">
    <div class="absolute inset-0">
      {post.image ? (
        <img 
          src={post.image} 
          alt={post.title}
          class="w-full h-full object-cover"
        />
      ) : (
        <div class="w-full h-full bg-gradient-to-br from-accent-blue to-accent-gold opacity-30"></div>
      )}
      <div class="absolute inset-0 bg-gradient-to-t from-dark via-dark/20 to-transparent"></div>
    </div>

    <div class="relative z-10 w-full pb-20">
      <div class="container-custom">
        <div class="max-w-4xl">
          {post.categories && post.categories.length > 0 && (
            <div class="flex flex-wrap gap-3 mb-6">
              {post.categories.map(cat => (
                <span class="glass-strong px-4 py-2 rounded-full text-sm font-medium backdrop-blur-md border border-white/20">
                  {cat}
                </span>
              ))}
            </div>
          )}

          <h1 class="text-5xl md:text-6xl lg:text-7xl font-display font-bold mb-6 leading-tight">
            {post.title}
          </h1>

          <div class="flex flex-wrap items-center gap-6 text-white/70">
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-accent-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <span>{formattedDate}</span>
            </div>

            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-accent-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>{readingTime} min read</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        
        <div class="lg:col-span-8">
          <article class="prose prose-invert prose-lg max-w-none
            [&_h2]:text-3xl [&_h2]:font-display [&_h2]:font-bold [&_h2]:mb-6 [&_h2]:mt-12 [&_h2]:gradient-text
            [&_h3]:text-2xl [&_h3]:font-display [&_h3]:font-bold [&_h3]:mb-4 [&_h3]:mt-8
            [&_p]:text-white/80 [&_p]:leading-relaxed [&_p]:mb-6
            [&_img]:rounded-2xl [&_img]:shadow-2xl [&_img]:my-8
            [&_a]:text-accent-blue [&_a]:hover:text-accent-gold [&_a]:transition-colors
            [&_ul]:text-white/80 [&_ul]:space-y-2 [&_ul]:mb-6
            [&_li]:marker:text-accent-gold
            [&_blockquote]:border-l-4 [&_blockquote]:border-accent-gold [&_blockquote]:pl-6 [&_blockquote]:italic [&_blockquote]:text-white/70 [&_blockquote]:my-8
            [&_hr]:border-white/10 [&_hr]:my-12">
            <Content />
          </article>

          <hr class="border-white/10 my-16" />

          <div class="glass-strong p-8 rounded-2xl">
            <h3 class="text-2xl font-display font-bold mb-6 gradient-text">Share This Article</h3>
            <div class="flex flex-wrap gap-4">
              <a 
                href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url)}`}
                target="_blank"
                class="flex items-center gap-3 px-6 py-3 rounded-full glass hover:bg-white/10 transition-all group"
              >
                <svg class="w-5 h-5 text-[#1877f2]" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.879v-6.99h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.99C18.343 21.128 22 16.991 22 12z"/>
                </svg>
                <span class="group-hover:text-white transition-colors">Facebook</span>
              </a>
              <a 
                href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.title)}&url=${encodeURIComponent(Astro.url)}`}
                target="_blank"
                class="flex items-center gap-3 px-6 py-3 rounded-full glass hover:bg-white/10 transition-all group"
              >
                <svg class="w-5 h-5 text-[#1da1f2]" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84"/>
                </svg>
                <span class="group-hover:text-white transition-colors">Twitter</span>
              </a>
              <a 
                href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url)}`}
                target="_blank"
                class="flex items-center gap-3 px-6 py-3 rounded-full glass hover:bg-white/10 transition-all group"
              >
                <svg class="w-5 h-5 text-[#0a66c2]" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                </svg>
                <span class="group-hover:text-white transition-colors">LinkedIn</span>
              </a>
            </div>
          </div>
        </div>

        <div class="lg:col-span-4">
          <div class="space-y-8 sticky top-24">
            <div class="glass-strong p-8 rounded-2xl">
              <h3 class="text-xl font-display font-bold mb-6 gradient-text">About the Author</h3>
              <div class="flex items-center gap-4 mb-6">
                <div class="w-20 h-20 rounded-full bg-gradient-to-br from-accent-blue to-accent-gold p-[2px]">
                  <div class="w-full h-full rounded-full bg-dark flex items-center justify-center">
                    <svg class="w-10 h-10 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                  </div>
                </div>
                <div>
                  <p class="text-xl font-bold">Planet Odysseys</p>
                  <p class="text-accent-gold">Travel Experts</p>
                </div>
              </div>
              <p class="text-white/70 leading-relaxed">
                Local travel experts passionate about sharing the authentic beauty of Lake Titicaca, Peru, and Bolivia through responsible and cultural tourism.
              </p>
            </div>

            <div class="glass p-6 rounded-2xl">
              <h3 class="text-lg font-bold mb-4 gradient-text">In this article</h3>
              <ul class="space-y-2 text-white/70">
                <li>
                  <a href="#" class="hover:text-accent-gold transition-colors flex items-center gap-2">
                    <span class="w-1 h-1 bg-accent-gold rounded-full"></span>
                    Introduction
                  </a>
                </li>
                <li>
                  <a href="#" class="hover:text-accent-gold transition-colors flex items-center gap-2">
                    <span class="w-1 h-1 bg-accent-gold rounded-full"></span>
                    Key Highlights
                  </a>
                </li>
                <li>
                  <a href="#" class="hover:text-accent-gold transition-colors flex items-center gap-2">
                    <span class="w-1 h-1 bg-accent-gold rounded-full"></span>
                    Travel Tips
                  </a>
                </li>
              </ul>
            </div>

            <div class="glass-hero p-8 rounded-2xl text-center">
              <h3 class="text-2xl font-bold mb-4">Ready to visit?</h3>
              <p class="text-white/70 mb-6">
                Experience these amazing places with our expert guides.
              </p>
              <a 
                href="/tours" 
                class="btn-premium inline-block w-full text-center"
              >
                <span>Explore Tours</span>
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  {relatedPosts.length > 0 && (
    <section class="pb-20">
      <div class="container-custom">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-3xl md:text-4xl font-display font-bold gradient-text">
            Related Articles
          </h2>
          <a href="/blog" class="text-accent-blue hover:text-accent-gold transition-colors flex items-center gap-2">
            View all
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {relatedPosts.map((relatedPost) => (
            <a 
              href={`/${relatedPost.slug}`}
              class="group block glass card-hover rounded-2xl overflow-hidden"
            >
              <div class="relative h-56 overflow-hidden">
                {relatedPost.image ? (
                  <img 
                    src={relatedPost.image} 
                    alt={relatedPost.title}
                    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                  />
                ) : (
                  <div class="w-full h-full bg-gradient-to-br from-accent-blue/20 to-accent-gold/20 flex items-center justify-center">
                    <svg class="w-16 h-16 text-white/20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                  </div>
                )}
                
                {relatedPost.categories && relatedPost.categories.length > 0 && (
                  <div class="absolute top-4 left-4">
                    <span class="glass-strong px-3 py-1 rounded-full text-xs font-semibold">
                      {relatedPost.categories[0]}
                    </span>
                  </div>
                )}
              </div>

              <div class="p-6">
                <p class="text-sm text-white/40 mb-2">
                  {formatBlogDate(relatedPost.date)}
                </p>
                <h3 class="text-lg font-bold mb-3 group-hover:text-accent-gold transition-colors line-clamp-2">
                  {relatedPost.title}
                </h3>
                <p class="text-white/60 text-sm line-clamp-3 mb-4">
                  {relatedPost.description}
                </p>
                <div class="flex items-center justify-between pt-4 border-t border-white/10">
                  <span class="text-sm text-white/40">Read article</span>
                  <span class="text-sm text-accent-blue group-hover:translate-x-2 transition-transform">
                    Read More →
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</main>

</BaseLayout>