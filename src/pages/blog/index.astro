---
// src/pages/blog/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllBlogPosts, getBlogCategories, formatBlogDate } from '../../data/blog';

const posts = await getAllBlogPosts();
const categories = await getBlogCategories();

const postsByYear: Record<string, typeof posts> = {};
posts.forEach(post => {
  const year = new Date(post.date).getFullYear().toString();
  if (!postsByYear[year]) postsByYear[year] = [];
  postsByYear[year].push(post);
});
---

<BaseLayout 
  title="Blog | Planet Odysseys"
  description="Travel tips, guides, and stories from Lake Titicaca, Peru, and Bolivia"
>

<main class="min-h-screen">

  <section class="relative h-[60vh] min-h-[500px] flex items-center overflow-hidden">
    <div class="absolute inset-0">
      <img 
        src="/images/blog-bg-planet-odysseys.webp" 
        alt="Planet Odysseys Blog"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-dark via-dark/50 to-dark/20"></div>
    </div>

    <div class="container-custom relative z-10">
      <div class="max-w-4xl">
        <div class="inline-block px-4 py-2 rounded-full bg-white/10 backdrop-blur-md text-sm font-semibold mb-6">
          {posts.length} Articles
        </div>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-display font-bold mb-6">
          Travel <span class="gradient-text">Blog</span>
        </h1>
        <p class="text-xl md:text-2xl text-gray-300 max-w-2xl leading-relaxed">
          Stories, guides, and tips from our adventures around Lake Titicaca, Peru, and Bolivia.
        </p>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>


  {categories.length > 0 && (
    <section class="py-8 border-b border-white/10 sticky top-20 z-40 glass backdrop-blur-xl">
      <div class="container-custom">
        <div class="flex items-center gap-4 overflow-x-auto no-scrollbar">
          <span class="text-sm text-gray-400 whitespace-nowrap">Categories:</span>
          <a href="/blog" class="px-4 py-2 rounded-full glass-strong hover:bg-white/10 transition-colors whitespace-nowrap text-sm">
            All
          </a>
          {categories.map(cat => (
            <a 
              href={`/blog/category/${cat.toLowerCase().replace(/\s+/g, '-')}`} 
              class="px-4 py-2 rounded-full glass-strong hover:bg-white/10 transition-colors whitespace-nowrap text-sm"
            >
              {cat}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}


  <section class="section-padding">
    <div class="container-custom">
      
  
      {Object.entries(postsByYear).sort((a, b) => Number(b[0]) - Number(a[0])).map(([year, yearPosts]) => (
        <div class="mb-16 last:mb-0">
          <h2 class="text-4xl font-display font-bold mb-8 gradient-text">
            {year}
          </h2>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {yearPosts.map((post) => (
              <a 
                href={`${post.slug}`}
                class="group block glass card-hover rounded-2xl overflow-hidden"
              >
  
                <div class="relative h-56 overflow-hidden bg-dark-200">
                  {post.image ? (
                    <img 
                      src={post.image}
                      alt={post.title}
                      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                      loading="lazy"
                    />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center">
                      <svg class="w-16 h-16 text-white/20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                    </div>
                  )}
                  

                  {post.categories && post.categories.length > 0 && (
                    <div class="absolute top-4 left-4 flex flex-wrap gap-2">
                      {post.categories.slice(0, 2).map(cat => (
                        <span class="glass-strong px-3 py-1 rounded-full text-xs font-semibold">
                          {cat}
                        </span>
                      ))}
                    </div>
                  )}
                </div>

                <div class="p-6">
 
                  <p class="text-sm text-white/40 mb-2">
                    {formatBlogDate(post.date)}
                  </p>

                  <h3 class="text-xl font-bold mb-3 group-hover:gradient-text transition-all line-clamp-2">
                    {post.title}
                  </h3>

                  {post.description && (
                    <p class="text-white/70 text-sm mb-4 line-clamp-3">
                      {post.description}
                    </p>
                  )}


                  <div class="flex items-center justify-between pt-4 border-t border-white/10">
                    <span class="text-sm text-white/40">Read article</span>
                    <span class="text-sm text-accent-blue font-semibold group-hover:translate-x-2 transition-transform">
                      Read More →
                    </span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}

     
      {posts.length === 0 && (
        <div class="glass p-12 text-center rounded-2xl">
          <p class="text-white/60 text-lg">
            No articles yet. Check back soon!
          </p>
        </div>
      )}

    </div>
  </section>

  
  <section class="section-padding bg-dark-100">
    <div class="container-custom">
      <div class="glass-strong rounded-3xl p-12 md:p-16 text-center max-w-4xl mx-auto">
        <h2 class="text-display-sm font-display font-bold mb-6">
          Join Our Newsletter
        </h2>
        <p class="text-xl text-gray-300 mb-8">
          Get travel tips, stories, and exclusive offers straight to your inbox.
        </p>
        <form class="flex flex-col sm:flex-row gap-4 max-w-lg mx-auto">
          <input 
            type="email" 
            placeholder="Your email address"
            class="flex-1 px-6 py-4 rounded-full bg-white/10 border border-white/20 focus:border-white/40 focus:outline-none text-white"
          />
          <button type="submit" class="btn-premium whitespace-nowrap">
            <span>Subscribe</span>
          </button>
        </form>
      </div>
    </div>
  </section>

</main>

</BaseLayout>