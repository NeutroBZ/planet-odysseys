---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Contact Us - Plan Your Peru Adventure"
  description="Get in touch with Planet Odysseys. WhatsApp, email, or phone - we're here to help plan your perfect Lake Titicaca experience."
  keywords={['contact Planet Odysseys', 'Peru tour inquiry', 'Lake Titicaca booking', 'travel agency Cusco']}
>
  <section class="section-padding">
    <div class="container-custom">
      <div class="max-w-6xl mx-auto">
        <!-- Header -->
        <div class="text-center mb-16">
          <div class="inline-block px-4 py-2 rounded-full bg-accent-blue/10 text-accent-blue text-sm font-semibold mb-4">
            Get in Touch
          </div>
          <h1 class="text-display-md font-display font-bold mb-6">
            Let's Plan Your <span class="gradient-text">Adventure</span>
          </h1>
          <p class="text-xl text-gray-400 max-w-2xl mx-auto">
            Have questions? Ready to book? Our local team in Cusco is here to help create your perfect Peru experience.
          </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
          <!-- Contact Form -->
          <div class="lg:col-span-3">
            <form class="glass-strong rounded-2xl p-8 space-y-6">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label for="name" class="block text-sm font-medium mb-2">Your Name *</label>
                  <input 
                    type="text" 
                    id="name" 
                    name="name" 
                    required
                    class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 focus:border-accent-blue focus:outline-none transition-colors"
                    placeholder="John Doe"
                  />
                </div>
                <div>
                  <label for="email" class="block text-sm font-medium mb-2">Email Address *</label>
                  <input 
                    type="email" 
                    id="email" 
                    name="email" 
                    required
                    class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 focus:border-accent-blue focus:outline-none transition-colors"
                    placeholder="john@example.com"
                  />
                </div>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label for="phone" class="block text-sm font-medium mb-2">Phone (optional)</label>
                  <input 
                    type="tel" 
                    id="phone" 
                    name="phone"
                    class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 focus:border-accent-blue focus:outline-none transition-colors"
                    placeholder="+1 234 567 8900"
                  />
                </div>
                <div>
                  <label for="travelers" class="block text-sm font-medium mb-2">Number of Travelers</label>
                  <select 
                    id="travelers" 
                    name="travelers"
                    class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 focus:border-accent-blue focus:outline-none transition-colors"
                  >
                    <option value="">Select...</option>
                    <option value="1">1 traveler</option>
                    <option value="2">2 travelers</option>
                    <option value="3-4">3-4 travelers</option>
                    <option value="5+">5+ travelers</option>
                  </select>
                </div>
              </div>

              <div>
                <label for="tour" class="block text-sm font-medium mb-2">Interested In</label>
                <select 
                  id="tour" 
                  name="tour"
                  class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 focus:border-accent-blue focus:outline-none transition-colors"
                >
                  <option value="">General inquiry</option>
                  <option value="uros">Uros Floating Islands</option>
                  <option value="amantani">Amantani Homestay Experience</option>
                  <option value="full-day">Lake Titicaca Full Day</option>
                  <option value="sun-route">Sun Route Cusco-Puno</option>
                  <option value="custom">Custom itinerary</option>
                </select>
              </div>

              <div>
                <label for="message" class="block text-sm font-medium mb-2">Your Message *</label>
                <textarea 
                  id="message" 
                  name="message" 
                  rows="6" 
                  required
                  class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 focus:border-accent-blue focus:outline-none transition-colors resize-none"
                  placeholder="Tell us about your travel plans, questions, or special requirements..."
                ></textarea>
              </div>

              <button type="submit" class="w-full btn-premium">
                <span>Send Message</span>
              </button>

              <p class="text-sm text-gray-400 text-center">
                We typically respond within 24 hours
              </p>
            </form>
          </div>

          <!-- Contact Info Sidebar -->
          <div class="lg:col-span-2 space-y-6">
            <!-- Quick Contact -->
            <div class="glass-strong rounded-2xl p-6 space-y-6">
              <h3 class="text-xl font-bold">Quick Contact</h3>
              
              <a 
                href="https://wa.me/51969355221" 
                target="_blank" 
                rel="noopener"
                class="flex items-center space-x-4 p-4 rounded-xl hover:bg-white/5 transition-colors group"
              >
                <div class="w-12 h-12 rounded-xl bg-green-500/20 flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-green-500" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                  </svg>
                </div>
                <div class="flex-1">
                  <div class="text-sm text-gray-400">WhatsApp</div>
                  <div class="font-semibold group-hover:text-green-500 transition-colors">+51 969 355 221</div>
                </div>
              </a>

              <a 
                href="mailto:tours@planetodysseys.com"
                class="flex items-center space-x-4 p-4 rounded-xl hover:bg-white/5 transition-colors group"
              >
                <div class="w-12 h-12 rounded-xl bg-accent-blue/20 flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-accent-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div class="flex-1">
                  <div class="text-sm text-gray-400">Email</div>
                  <div class="font-semibold group-hover:text-accent-blue transition-colors">tours@planetodysseys.com</div>
                </div>
              </a>

              <a 
                href="tel:+51969355221"
                class="flex items-center space-x-4 p-4 rounded-xl hover:bg-white/5 transition-colors group"
              >
                <div class="w-12 h-12 rounded-xl bg-accent-violet/20 flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-accent-violet" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div class="flex-1">
                  <div class="text-sm text-gray-400">Phone</div>
                  <div class="font-semibold group-hover:text-accent-violet transition-colors">+51 969 355 221</div>
                </div>
              </a>
            </div>

            <!-- Office Location -->
            <div class="glass-strong rounded-2xl p-6 space-y-4">
              <h3 class="text-xl font-bold">Our Office</h3>
              <div class="space-y-3 text-gray-300">
                <p class="flex items-start space-x-3">
                  <svg class="w-5 h-5 text-accent-pink flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  <span>
                    Jr. Cuba J7-B<br />
                    Urb. Quispicanchis<br />
                    Cusco 08003, Peru
                  </span>
                </p>
              </div>
            </div>

            <!-- Business Info -->
            <div class="glass-strong rounded-2xl p-6 space-y-4">
              <h3 class="text-xl font-bold">Business Details</h3>
              <div class="space-y-2 text-sm text-gray-400">
                <p><span class="text-white font-medium">Company:</span> Planet Odysseys E.I.R.L.</p>
                <p><span class="text-white font-medium">RUC:</span> 2060999824</p>
                <p><span class="text-white font-medium">Licensed:</span> Peruvian Tourism Authority</p>
              </div>
            </div>

            <!-- Response Time -->
            <div class="glass-strong rounded-2xl p-6 space-y-4 text-center">
              <div class="w-16 h-16 rounded-full bg-accent-blue/20 flex items-center justify-center mx-auto">
                <svg class="w-8 h-8 text-accent-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <div class="text-2xl font-bold gradient-text">24 Hours</div>
                <div class="text-sm text-gray-400 mt-2">Average response time</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Form handling
  const form = document.querySelector('form');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(form as HTMLFormElement);
    const data = Object.fromEntries(formData);
    
    // Here you would typically send to your backend
    console.log('Form submitted:', data);
    
    // Show success message
    alert('Thank you! We\'ll get back to you within 24 hours.');
    (form as HTMLFormElement).reset();
  });
</script>
