---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { destinations } from '../../data/destinations';
import { tours } from '../../data/tours';


// Agregar tourCount a cada destino
const destinationsWithCount = destinations.map(dest => ({
  ...dest,
  tourCount: dest.category 
    ? tours.filter(t => t.category === dest.category).length 
    : 0
}));
---

<BaseLayout 
  title="Destinations in Peru & Bolivia | Planet Odysseys"
  description="Explore our destinations: Lake Titicaca, Colca Canyon, and Bolivia. Discover authentic travel experiences in South America."
>

<main class="min-h-screen">
  <section class="relative h-[80vh] min-h-[700px] overflow-hidden">
    <div class="absolute inset-0">
      <img 
        src="/images/destinations-bg-planet-odysseys.webp" 
        alt="Destinations in Peru and Bolivia"
        class="w-full h-full object-cover"
      />
    </div>
    <div class="absolute inset-0 bg-gradient-to-r from-[#0a3a4d] via-[#0a3a4d]/50 to-transparent"></div>
    <div class="absolute inset-0 animated-gradient opacity-30"></div>

    <div class="container-custom relative z-10 h-full flex items-center">
      <div class="max-w-3xl">
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-display font-bold mb-6">
          Our <span class="gradient-text">Destinations</span>
        </h1>
        <p class="text-xl text-white/80 leading-relaxed">
          From the floating islands of Lake Titicaca to the depths of Colca Canyon and the salt flats of Bolivia.
        </p>
      </div>
    </div>
  </section>

  {/* Destinations Grid */}
  <section class="section-padding">
    <div class="container-custom">

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

        {destinationsWithCount.map((dest) => (
          <a 
            href={`/destinations/${dest.slug}`}
            class="group block glass card-hover rounded-2xl overflow-hidden"
          >

            {/* Image with overlay */}
            <div class="relative h-64 overflow-hidden">
              <img 
                src={dest.image}
                alt={dest.name}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
              />
              <div class={`absolute inset-0 bg-gradient-to-t ${dest.gradient} opacity-60`}></div>
              
              {/* Content overlay */}
              <div class="absolute bottom-0 left-0 right-0 p-6">
                <h3 class="text-3xl font-display font-bold mb-1">{dest.name}</h3>
                <p class="text-white/90 text-sm mb-2">{dest.subtitle}</p>
                <div class="flex items-center gap-2">
                  <span class="glass px-3 py-1 rounded-full text-xs">
                    {dest.tourCount} Tours Available
                  </span>
                </div>
              </div>
            </div>

            {/* Description */}
            <div class="p-6">
              <p class="text-white/70 text-sm mb-4">
                {dest.description}
              </p>

              {/* Footer */}
              <div class="flex items-center justify-between">
                <span class="text-sm text-white/40">Explore Destination</span>
                <span class="text-sm group-hover:translate-x-2 transition-transform">
                  View Tours →
                </span>
              </div>
            </div>
          </a>
        ))}

      </div>

    </div>
  </section>

  {/* CTA */}
  <section class="py-32 glass-hero">
    <div class="container-custom text-center">
      <h2 class="text-4xl md:text-5xl font-display font-bold mb-6">
        Ready to Explore?
      </h2>
      <p class="text-xl text-white/80 mb-12 max-w-2xl mx-auto">
        Browse our tours by destination or contact us to create your perfect itinerary.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/tour" class="btn-premium">
          <span>View All Tours</span>
        </a>
        <a href="/contact" class="glass-strong px-8 py-4 rounded-full font-semibold hover:bg-white/10 transition-colors">
          Contact Us
        </a>
      </div>
    </div>
  </section>
</main>

</BaseLayout>