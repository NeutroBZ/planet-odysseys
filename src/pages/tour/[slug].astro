---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTourBySlug, getAllTourSlugs, getToursByCategory } from '../../data/tours';

export async function getStaticPaths() {
  const slugs = getAllTourSlugs();
  return slugs.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const tour = getTourBySlug(slug!);

if (!tour) {
  return Astro.redirect('/404');
}

const relatedTours = getToursByCategory(tour.category)
  .filter(t => t.id !== tour.id)
  .slice(0, 3);

const formatPrice = (price: number) => {
  return new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: 'USD',
    minimumFractionDigits: 0,
    maximumFractionDigits: 0
  }).format(price);
};

const categoryLabels = {
  'lake-titicaca': 'Lake Titicaca',
  'bolivia': 'Bolivia',
  'transfers': 'Transfer',
  'packages': 'Package'
};
---

<BaseLayout 
  title={`${tour.title} | Planet Odysseys`}
  description={tour.metaDescription}
>
  <main class="min-h-screen">
    {/* Hero Section */}
    <section class="relative h-[70vh] min-h-[600px] overflow-hidden">
      <div class="absolute inset-0">
        <img 
          src={tour.image} 
          alt={tour.title}
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-[#001a24] via-[#001a24]/50 to-transparent"></div>
      </div>

      <div class="absolute bottom-0 left-0 right-0 pb-20">
        <div class="container-custom">
          <div class="max-w-4xl">
            <div class="flex items-center gap-4 mb-4">
              <span class="glass px-4 py-2 rounded-full text-sm">
                {categoryLabels[tour.category]}
              </span>
              {tour.featured && (
                <span class="bg-[#c6a15b] text-[#001a24] px-4 py-2 rounded-full text-sm font-semibold">
                  Featured Tour
                </span>
              )}
            </div>

            <h1 class="text-5xl md:text-6xl lg:text-7xl font-display font-bold mb-6">
              {tour.title}
            </h1>

            <div class="flex flex-wrap items-center gap-6 text-lg">
              <div class="flex items-center gap-2">
                <span>{tour.duration}</span>
              </div>
              <div class="flex items-center gap-2">
                <span>{tour.destination}</span>
              </div>
              {tour.rating > 0 && (
                <div class="flex items-center gap-2">
                  <span class="text-[#c6a15b]">★</span>
                  <span class="font-bold">{tour.rating}</span>
                  <span class="text-white/60">({tour.reviews} reviews)</span>
                </div>
              )}
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Contenido Principal */}
    <section class="section-padding">
      <div class="container-custom">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
          {/* Columna Principal */}
          <div class="lg:col-span-2 space-y-16">
            {/* Overview - Usa el nuevo campo overview si existe, si no usa description */}
            <div>
              <h2 class="text-3xl font-display font-bold mb-6">Overview</h2>
              {tour.overview ? (
                <div 
                  class="prose prose-invert prose-p:text-white/80 prose-p:leading-relaxed prose-p:mb-4 prose-strong:text-[#c6a15b] prose-em:text-white/60 prose-a:text-[#c6a15b] prose-a:no-underline hover:prose-a:underline max-w-none"
                  set:html={tour.overview}
                />
              ) : (
                <p class="text-lg text-white/80 leading-relaxed">{tour.description}</p>
              )}
            </div>

            {/* What to Expect - Nuevo campo */}
            {tour.whatToExpect && (
              <div class="glass p-8 rounded-2xl">
                <h2 class="text-3xl font-display font-bold mb-6">What to Expect on Your Tour?</h2>
                <div 
                  class="prose prose-invert prose-p:text-white/80 prose-p:leading-relaxed prose-p:mb-4 max-w-none"
                  set:html={tour.whatToExpect.description}
                />
                
                {tour.whatToExpect.quickFacts && tour.whatToExpect.quickFacts.length > 0 && (
                  <div class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-4">
                    {tour.whatToExpect.quickFacts.map((fact) => (
                      <div class="flex items-start gap-3">
                        <span class="text-[#c6a15b] text-xl">•</span>
                        <span class="text-white/80 text-sm">{fact}</span>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            )}

            {/* Highlights */}
            <div>
              <h2 class="text-3xl font-display font-bold mb-6">Tour Highlights</h2>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                {tour.highlights.map((highlight) => (
                  <div class="flex items-start gap-3">
                    <span class="text-[#c6a15b] text-xl">✓</span>
                    <span class="text-white/80">{highlight}</span>
                  </div>
                ))}
              </div>
            </div>

            {/* Itinerario con Acordeón - Todos los tours usan el mismo sistema */}
            <div>
              <h2 class="text-3xl font-display font-bold mb-8">Tour Itinerary</h2>
              
              <div class="space-y-4">
                {tour.itinerary.map((day) => (
                  <div class="glass rounded-2xl overflow-hidden">
                    <details class="group" open>
                      <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
                        <div class="flex items-center gap-4">
                          <span class="bg-[#c6a15b] text-[#001a24] w-12 h-12 rounded-full flex items-center justify-center font-bold text-xl flex-shrink-0">
                            {day.day}
                          </span>
                          <div>
                            <h3 class="text-2xl font-bold text-left">{day.title}</h3>
                            <p class="text-white/60 text-left">{day.description}</p>
                          </div>
                        </div>
                        {/* Ícono ^ que rota 180° cuando está abierto */}
                        <span class="text-[#c6a15b] text-2xl transition-transform duration-300 group-open:rotate-180">^</span>
                      </summary>
                      <div class="px-6 pb-6 pt-2 border-t border-white/10">
                        <div class="prose prose-invert max-w-none 
                          prose-p:text-white/80 prose-p:leading-relaxed prose-p:mb-4 prose-p:ml-0
                          prose-h4:text-white prose-h4:text-xl prose-h4:font-bold prose-h4:mt-6 prose-h4:mb-3 prose-h4:ml-0
                          prose-ul:text-white/80 prose-ul:my-4 prose-ul:pl-6
                          prose-li:text-white/80 prose-li:my-1
                          prose-strong:text-[#c6a15b]">
                          {day.activities.map((activity) => (
                            <div set:html={activity} />
                          ))}
                        </div>
                      </div>
                    </details>
                  </div>
                ))}
              </div>
            </div>

            {/* Itinerario Detallado (solo si existe y no estamos usando ya overview extendido) */}
            {tour.detailedItinerary && !tour.overview && (
              <div>
                <h2 class="text-3xl font-display font-bold mb-6">Complete Tour Description</h2>
                <div 
                  class="glass p-8 rounded-2xl prose prose-invert prose-headings:text-white prose-h3:text-2xl prose-h4:text-xl prose-p:text-white/80 prose-li:text-white/80 prose-strong:text-[#c6a15b] prose-ul:list-disc prose-ul:pl-6 max-w-none"
                  set:html={tour.detailedItinerary}
                />
              </div>
            )}

            {/* Incluye / No Incluye */}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <div class="glass p-8 rounded-2xl">
                <h3 class="text-2xl font-bold mb-4 text-green-400">✓ Includes</h3>
                <ul class="space-y-3">
                  {tour.includes.map((item) => (
                    <li class="flex items-start gap-3">
                      <span class="text-green-400">✓</span>
                      <span class="text-white/80">{item}</span>
                    </li>
                  ))}
                </ul>
              </div>

              <div class="glass p-8 rounded-2xl">
                <h3 class="text-2xl font-bold mb-4 text-red-400">✗ Not Included</h3>
                <ul class="space-y-3">
                  {tour.notIncludes.map((item) => (
                    <li class="flex items-start gap-3">
                      <span class="text-red-400">✗</span>
                      <span class="text-white/80">{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            {/* Información Importante */}
            {tour.importantInfo.length > 0 && (
              <div>
                <h2 class="text-3xl font-display font-bold mb-6">Important Information</h2>
                <div class="glass p-8 rounded-2xl">
                  <ul class="space-y-4">
                    {tour.importantInfo.map((info) => (
                      <li class="flex items-start gap-3">
                        <span class="text-[#c6a15b] text-xl">•</span>
                        <span class="text-white/80">{info}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            )}
          </div>

          {/* Sidebar - sin cambios */}
          <div class="lg:col-span-1">
            <div class="glass-strong p-8 rounded-2xl sticky top-24">
              {/* Precio */}
              <div class="text-center mb-8">
                <span class="text-sm text-white/60">Price from</span>
                <div class="text-5xl font-bold text-[#c6a15b] my-2">
                  {formatPrice(tour.price)}
                </div>
                <span class="text-white/60">per person</span>
              </div>

              {/* Botones con WeTravel */}
              <div class="space-y-4">
                {tour.wetravel ? (
                  <div id="wetravel-widget" class="min-h-[50px]"></div>
                ) : (
                  <a 
                    href={`/contact?tour=${tour.slug}`}
                    class="btn-premium w-full text-center block"
                  >
                    <span>Book This Tour</span>
                  </a>
                )}
                
                <a 
                  href="/contact" 
                  class="glass block w-full text-center px-8 py-4 rounded-full font-semibold hover:bg-white/10 transition-colors"
                >
                  Contact Us
                </a>
              </div>

              {/* Detalles rápidos */}
              <div class="mt-8 pt-8 border-t border-white/10">
                <div class="space-y-4">
                  <div class="flex justify-between">
                    <span class="text-white/60">Duration</span>
                    <span class="font-medium">{tour.duration}</span>
                  </div>
                  <div class="flex justify-between">
                    <span class="text-white/60">Destination</span>
                    <span class="font-medium text-right text-sm">{tour.destination}</span>
                  </div>
                  <div class="flex justify-between">
                    <span class="text-white/60">Category</span>
                    <span class="font-medium">{categoryLabels[tour.category]}</span>
                  </div>
                  {tour.rating > 0 && (
                    <div class="flex justify-between">
                      <span class="text-white/60">Rating</span>
                      <span class="font-medium flex items-center gap-1">
                        <span class="text-[#c6a15b]">★</span> {tour.rating} ({tour.reviews})
                      </span>
                    </div>
                  )}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Tours Relacionados */}
    {relatedTours.length > 0 && (
      <section class="pb-20">
        <div class="container-custom">
          <h2 class="text-3xl font-display font-bold mb-8">You Might Also Like</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {relatedTours.map((relatedTour) => (
              <a 
                href={`/tour/${relatedTour.slug}`}
                class="group block glass card-hover rounded-2xl overflow-hidden"
              >
                <div class="relative h-56">
                  <img 
                    src={relatedTour.image} 
                    alt={relatedTour.title}
                    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                    loading="lazy"
                  />
                </div>
                <div class="p-6">
                  <h3 class="text-xl font-bold mb-2 group-hover:text-[#c6a15b] transition-colors">
                    {relatedTour.shortTitle}
                  </h3>
                  <p class="text-white/60 text-sm mb-4 line-clamp-2">
                    {relatedTour.description}
                  </p>
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-white/40">{relatedTour.duration}</span>
                    <span class="text-[#c6a15b] font-bold">{formatPrice(relatedTour.price)}</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* Booking CTA */}
    <section class="py-20 glass-hero">
      <div class="container-custom text-center">
        <h2 class="text-4xl md:text-5xl font-display font-bold mb-6">
          Ready to Experience {tour.shortTitle}?
        </h2>
        <p class="text-xl text-white/80 mb-8 max-w-2xl mx-auto">
          Book now or contact us for more information about this amazing tour.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          {tour.wetravel ? (
            <a href="#wetravel-widget" class="btn-premium scroll-smooth">
              <span>Book This Tour</span>
            </a>
          ) : (
            <a href={`/contact?tour=${tour.slug}`} class="btn-premium">
              <span>Book This Tour</span>
            </a>
          )}
          <a href="/contact" class="glass-strong px-8 py-4 rounded-full font-semibold hover:bg-white/10 transition-colors">
            Contact Us
          </a>
        </div>
      </div>
    </section>
  </main>

  {/* Script de WeTravel */}
  {tour.wetravel && (
    <script 
      define:vars={{ uid: tour.wetravel.uid, uuid: tour.wetravel.uuid }}
      is:inline
    >
      (function() {
        const script = document.createElement('script');
        script.src = 'https://cdn.wetravel.com/widgets/embed_calendar.js';
        script.id = 'wetravel_embed_calendar';
        script.setAttribute('data-env', 'https://www.wetravel.com');
        script.setAttribute('data-version', 'v0.3');
        script.setAttribute('data-uid', uid);
        script.setAttribute('data-uuid', uuid);
        script.setAttribute('data-color', 'c6a15b');
        script.setAttribute('data-text', 'Book Now');
        script.setAttribute('data-title', 'Select Departure Date');
        
        const container = document.getElementById('wetravel-widget');
        if (container) {
          container.appendChild(script);
        }
      })();
    </script>
  )}
</BaseLayout>

<style is:global>
  details > summary {
    list-style: none;
  }
  details > summary::-webkit-details-marker {
    display: none;
  }
  details[open] summary {
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }
  .scroll-smooth {
    scroll-behavior: smooth;
  }
</style>