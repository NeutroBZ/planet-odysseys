---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { tours } from '../../data/tours';

type CategoryKey =
  | 'lake-titicaca'
  | 'bolivia'
  | 'transfers'
  | 'packages';

const toursByCategory: Record<CategoryKey, typeof tours> = {
  'lake-titicaca': tours.filter(t => t.category === 'lake-titicaca'),
  'bolivia': tours.filter(t => t.category === 'bolivia'),
  'transfers': tours.filter(t => t.category === 'transfers'),
  'packages': tours.filter(t => t.category === 'packages')
};

const categoryInfo: Record<CategoryKey, { title: string; description: string }> = {
  'lake-titicaca': {
    title: 'Lake Titicaca Tours',
    description: "Discover the magical floating islands, ancient cultures, and stunning landscapes of the world's highest navigable lake."
  },
  'bolivia': {
    title: 'Bolivia Adventures',
    description: "Cross-border experiences to Bolivia's most spectacular destinations, including the otherworldly Uyuni Salt Flats."
  },
  'transfers': {
    title: 'Transfers & Transportation',
    description: "Comfortable and reliable transfers between Peru's top destinations, including scenic routes and private services."
  },
  'packages': {
    title: 'Travel Packages',
    description: 'Curated multi-day packages combining the best of Lake Titicaca, Cusco, and beyond.'
  }
};


const categoryLabels: Record<CategoryKey, string> = {
  'lake-titicaca': 'Lake Titicaca',
  'bolivia': 'Bolivia',
  'transfers': 'Transfer',
  'packages': 'Package'
};


const categoriesData = (Object.entries(toursByCategory) as Array<[CategoryKey, typeof tours]>).map(([category, categoryTours]) => ({
  category,
  categoryTours,
  info: categoryInfo[category],
  label: categoryLabels[category]
}));


const formatPrice = (price: number) => {
  return new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: 'USD',
    minimumFractionDigits: 0,
    maximumFractionDigits: 0
  }).format(price);
};
---

<BaseLayout 
  title="All Tours & Experiences | Planet Odysseys"
  description="Browse our complete collection of Lake Titicaca tours, Bolivia adventures, transfers, and travel packages."
>

<main class="min-h-screen">

  {/* Hero Section con Imagen */}
  <section class="relative h-[60vh] min-h-[500px] flex items-center overflow-hidden">
    {/* Background Image */}
    <div class="absolute inset-0">
      <img 
        src="/images/tours-bg-planet-odysseys.webp" 
        alt="Lake Titicaca Tours"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-dark via-dark/70 to-dark/50"></div>
    </div>

    {/* Content */}
    <div class="container-custom relative z-10">
      <div class="max-w-4xl">
        <div class="inline-block px-4 py-2 rounded-full bg-white/10 backdrop-blur-md text-sm font-semibold mb-6">
          {tours.length} Tours Available
        </div>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-display font-bold mb-6">
          All Tours & <span class="gradient-text">Experiences</span>
        </h1>
        <p class="text-xl md:text-2xl text-gray-300 max-w-2xl leading-relaxed">
          Browse our complete collection of authentic Lake Titicaca tours, Bolivia adventures, and seamless transfers across Peru.
        </p>
      </div>
    </div>

    {/* Scroll Indicator */}
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>

  {/* Quick Navigation */}
  <section class="py-8 border-b border-white/10 sticky top-20 z-40 glass backdrop-blur-xl">
    <div class="container-custom">
      <div class="flex items-center gap-4 overflow-x-auto no-scrollbar">
        <span class="text-sm text-gray-400 whitespace-nowrap">Jump to:</span>
        <a href="#lake-titicaca" class="px-4 py-2 rounded-full glass-strong hover:bg-white/10 transition-colors whitespace-nowrap text-sm">
          Lake Titicaca
        </a>
        <a href="#bolivia" class="px-4 py-2 rounded-full glass-strong hover:bg-white/10 transition-colors whitespace-nowrap text-sm">
          Bolivia
        </a>
        <a href="#transfers" class="px-4 py-2 rounded-full glass-strong hover:bg-white/10 transition-colors whitespace-nowrap text-sm">
          Transfers
        </a>
        <a href="#packages" class="px-4 py-2 rounded-full glass-strong hover:bg-white/10 transition-colors whitespace-nowrap text-sm">
          Packages
        </a>
      </div>
    </div>
  </section>

  {/* Tours by Category */}
  <section class="section-padding">
    <div class="container-custom space-y-24">

      {categoriesData.map(({ category, categoryTours, info, label }) => (
        <div class="scroll-mt-24" id={category}>

          {/* Category Header */}
          <div class="mb-12">
            <h2 class="text-4xl md:text-5xl font-display font-bold mb-4 gradient-text">
              {info.title}
            </h2>
            <p class="text-lg text-white/70 max-w-2xl">
              {info.description}
            </p>
          </div>

          {/* Grid */}
          {categoryTours.length > 0 ? (
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

              {categoryTours.map((tour) => (
                <a 
                  href={`/tour/${tour.slug}`}
                  class="group block glass card-hover rounded-2xl overflow-hidden"
                >

                  <div class="relative h-72 overflow-hidden">
                    <img 
                      src={tour.image}
                      alt={tour.title}
                      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                      loading="lazy"
                    />

                    <div class="absolute top-4 left-4 flex flex-wrap gap-2">
                      {tour.featured && (
                        <span class="glass-strong px-3 py-1 rounded-full text-sm font-semibold">
                          Featured
                        </span>
                      )}
                      <span class="glass px-3 py-1 rounded-full text-sm font-semibold">
                        {label}
                      </span>
                    </div>

                    <div class="absolute bottom-4 right-4">
                      <div class="glass-strong px-4 py-2 rounded-full">
                        <span class="text-sm text-white/70">from</span>
                        <span class="text-xl font-bold ml-1">
                          {formatPrice(tour.price)}
                        </span>
                      </div>
                    </div>
                  </div>

                  <div class="p-6">
                    <h3 class="text-xl font-bold mb-2 group-hover:gradient-text transition-all">
                      {tour.shortTitle}
                    </h3>

                    <p class="text-white/70 text-sm mb-4 line-clamp-2">
                      {tour.description}
                    </p>

                    <div class="flex items-center gap-4 text-sm text-white/60 mb-4">
                      <span>{tour.duration}</span>
                      <span>•</span>
                      <span>{tour.destination}</span>
                    </div>

                    <div class="flex items-center justify-between pt-4 border-t border-white/10">
                      <div class="flex items-center space-x-1 text-sm text-gray-400">
                        <svg class="w-4 h-4 text-accent-blue" fill="currentColor" viewBox="0 0 20 20">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                        <span>{tour.rating} ({tour.reviews})</span>
                      </div>
                      <span class="text-sm text-accent-blue font-semibold group-hover:translate-x-2 transition-transform">
                        View Details →
                      </span>
                    </div>
                  </div>

                </a>
              ))}

            </div>
          ) : (
            <div class="glass p-12 text-center rounded-2xl">
              <p class="text-white/60 text-lg">
                No tours available in this category yet. Check back soon!
              </p>
            </div>
          )}

        </div>
      ))}

    </div>
  </section>

  {/* CTA Section */}
  <section class="section-padding bg-dark-100">
    <div class="container-custom">
      <div class="glass-strong rounded-3xl p-12 md:p-16 text-center max-w-4xl mx-auto">
        <h2 class="text-display-sm font-display font-bold mb-6">
          Can't Find What You're Looking For?
        </h2>
        <p class="text-xl text-gray-300 mb-8">
          We specialize in custom itineraries. Contact us to create your perfect Peru adventure.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/contact" class="btn-premium">
            <span>Contact Us</span>
          </a>
          <a 
            href="https://wa.me/51969355221" 
            target="_blank" 
            rel="noopener"
            class="px-8 py-4 rounded-full font-semibold text-white border-2 border-white/20 hover:border-white/40 transition-all duration-300 hover:bg-white/5 flex items-center space-x-2"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
            <span>WhatsApp Us</span>
          </a>
        </div>
      </div>
    </div>
  </section>

</main>

</BaseLayout>