---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { tours } from '../../data/tours';

/* ================================
   TYPES
================================ */

type CategoryKey =
  | 'lake-titicaca'
  | 'bolivia'
  | 'transfers'
  | 'packages';

/* ================================
   TOURS BY CATEGORY
================================ */

const toursByCategory: Record<CategoryKey, typeof tours> = {
  'lake-titicaca': tours.filter(t => t.category === 'lake-titicaca'),
  'bolivia': tours.filter(t => t.category === 'bolivia'),
  'transfers': tours.filter(t => t.category === 'transfers'),
  'packages': tours.filter(t => t.category === 'packages')
};

/* ================================
   CATEGORY INFO
================================ */

const categoryInfo: Record<
  CategoryKey,
  { title: string; description: string }
> = {
  'lake-titicaca': {
    title: 'Lake Titicaca Tours',
    description:
      "Discover the magical floating islands, ancient cultures, and stunning landscapes of the world's highest navigable lake."
  },
  'bolivia': {
    title: 'Bolivia Adventures',
    description:
      "Cross-border experiences to Bolivia's most spectacular destinations, including the otherworldly Uyuni Salt Flats."
  },
  'transfers': {
    title: 'Transfers & Transportation',
    description:
      "Comfortable and reliable transfers between Peru's top destinations, including scenic routes and private services."
  },
  'packages': {
    title: 'Travel Packages',
    description:
      'Curated multi-day packages combining the best of Lake Titicaca, Cusco, and beyond.'
  }
};

/* ================================
   CATEGORY LABELS
================================ */

const categoryLabels: Record<CategoryKey, string> = {
  'lake-titicaca': 'Lake Titicaca',
  'bolivia': 'Bolivia',
  'transfers': 'Transfer',
  'packages': 'Package'
};

/* ================================
   PRICE FORMAT
================================ */

const formatPrice = (price: number) => {
  return new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: 'USD',
    minimumFractionDigits: 0,
    maximumFractionDigits: 0
  }).format(price);
};
---

<BaseLayout 
  title="All Tours & Experiences | Planet Odysseys"
  description="Browse our complete collection of Lake Titicaca tours, Bolivia adventures, transfers, and travel packages."
>

<main class="min-h-screen">

  {/* Tours by Category */}
  <section class="section-padding">
    <div class="container-custom space-y-24">

      {(Object.entries(toursByCategory) as [CategoryKey, typeof tours][])
        .map(([category, categoryTours]) => (

        <div class="scroll-mt-24" id={category}>

          {/* Category Header */}
          <div class="mb-12">
            <h2 class="text-4xl md:text-5xl font-display font-bold mb-4 gradient-text">
              {categoryInfo[category].title}
            </h2>
            <p class="text-lg text-white/70 max-w-2xl">
              {categoryInfo[category].description}
            </p>
          </div>

          {/* Grid */}
          {categoryTours.length > 0 ? (
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

              {categoryTours.map((tour) => (
                <a 
                  href={`/tour/${tour.slug}`}
                  class="group block glass card-hover rounded-2xl overflow-hidden"
                >

                  <div class="relative h-72 overflow-hidden">
                    <img 
                      src={tour.image}
                      alt={tour.title}
                      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                    />

                    <div class="absolute top-4 left-4 flex flex-wrap gap-2">
                      {tour.featured && (
                        <span class="glass-strong px-3 py-1 rounded-full text-sm font-semibold">
                          Featured
                        </span>
                      )}
                      <span class="glass px-3 py-1 rounded-full text-sm font-semibold">
                        {categoryLabels[tour.category as CategoryKey]}
                      </span>
                    </div>

                    <div class="absolute bottom-4 right-4">
                      <div class="glass-strong px-4 py-2 rounded-full">
                        <span class="text-sm text-white/70">from</span>
                        <span class="text-xl font-bold ml-1">
                          {formatPrice(tour.price)}
                        </span>
                      </div>
                    </div>
                  </div>

                  <div class="p-6">
                    <h3 class="text-xl font-bold mb-2 group-hover:gradient-text transition-all">
                      {tour.shortTitle}
                    </h3>

                    <p class="text-white/70 text-sm mb-4 line-clamp-2">
                      {tour.description}
                    </p>

                    <div class="flex items-center gap-4 text-sm text-white/60 mb-4">
                      <span>{tour.duration}</span>
                      <span>{tour.destination}</span>
                    </div>

                    <div class="flex items-center justify-between">
                      <span class="text-sm text-white/40">
                        View Details
                      </span>
                      <span class="text-sm group-hover:translate-x-2 transition-transform">
                        →
                      </span>
                    </div>
                  </div>

                </a>
              ))}

            </div>
          ) : (
            <div class="glass p-12 text-center rounded-2xl">
              <p class="text-white/60 text-lg">
                No tours available in this category yet.
              </p>
            </div>
          )}

        </div>
      ))}

    </div>
  </section>

</main>

</BaseLayout>