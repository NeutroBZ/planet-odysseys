---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  keywords?: string[];
}

const { 
  title, 
  description, 
  image = '/images/og-default.jpg',
  keywords = []
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <meta name="generator" content={Astro.generator} />
 
    <!-- SEO Meta Tags -->
    <title>{title} | Planet Odysseys</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords.join(', ')} />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | Planet Odysseys`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={`${title} | Planet Odysseys`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap" rel="stylesheet" />
    
    <!-- Preload Critical Assets -->
    <link rel="preload" as="image" href="/images/bg-planet-odysseyss.webp" />
  </head>
  <body class="bg-dark text-white">
    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 glass backdrop-blur-2xl border-b border-white/10">
      <div class="container-custom">
        <div class="flex items-center justify-between h-20">
          <!-- Logo -->
          <a href="/" class="flex items-center space-x-3 group">
            <img 
              src="/images/logo-planet.webp" 
              alt="Planet Odysseys Logo"
              class="h-12 w-auto transition-transform group-hover:scale-105"
            />
          </a>

          <!-- Desktop Navigation -->
          <div class="hidden lg:flex items-center space-x-8">
            <a 
              href="/destinations" 
              class={`text-sm font-medium transition-colors ${currentPath.includes('/destinations') ? 'text-white' : 'text-gray-400 hover:text-white'}`}
            >
              Destinations
            </a>
            <a 
              href="/tour" 
              class={`text-sm font-medium transition-colors ${currentPath.includes('/tours') ? 'text-white' : 'text-gray-400 hover:text-white'}`}
            >
              Tours
            </a>
            <a 
              href="/transfers" 
              class={`text-sm font-medium transition-colors ${currentPath.includes('/transfers') ? 'text-white' : 'text-gray-400 hover:text-white'}`}
            >
              Transfers
            </a>
            <!--- <a 
              href="/blog" 
              class={`text-sm font-medium transition-colors ${currentPath.includes('/blog') ? 'text-white' : 'text-gray-400 hover:text-white'}`}
            >
              Stories
            </a>-->
            <a 
              href="/about" 
              class={`text-sm font-medium transition-colors ${currentPath.includes('/about') ? 'text-white' : 'text-gray-400 hover:text-white'}`}
            >
              About
            </a>
          </div>

          <!-- CTA Button -->
          <div class="hidden lg:block">
            <a href="/contact" class="btn-premium">
              <span>Plan Your Journey</span>
            </a>
          </div>

          <!-- Mobile Menu Button -->
          <button 
            id="mobile-menu-button"
            class="lg:hidden p-2 rounded-lg hover:bg-white/5 transition-colors"
            aria-label="Toggle menu"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile Menu -->
      <div id="mobile-menu" class="hidden lg:hidden border-t border-white/10">
        <div class="container-custom py-4 space-y-2">
          <a href="/destinations" class="block py-2 text-sm font-medium text-gray-400 hover:text-white transition-colors">
            Destinations
          </a>
          <a href="/tours" class="block py-2 text-sm font-medium text-gray-400 hover:text-white transition-colors">
            Tours
          </a>
          <a href="/transfers" class="block py-2 text-sm font-medium text-gray-400 hover:text-white transition-colors">
            Transfers
          </a>
          <a href="/blog" class="block py-2 text-sm font-medium text-gray-400 hover:text-white transition-colors">
            Stories
          </a>
          <a href="/about" class="block py-2 text-sm font-medium text-gray-400 hover:text-white transition-colors">
            About
          </a>
          <a href="/contact" class="block py-2 text-sm font-medium text-white">
            Contact Us
          </a>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="pt-20">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="section-padding bg-dark-100 border-t border-white/10">
      <div class="container-custom">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
          <!-- Company Info -->
          <div class="space-y-4">
            <div class="flex items-center space-x-3">
              <div class="w-10 h-10 rounded-full bg-gradient-odyssey p-[2px]">
                <div class="w-full h-full rounded-full bg-dark flex items-center justify-center">
                  <span class="text-lg font-bold gradient-text">PO</span>
                </div>
              </div>
              <span class="text-lg font-display font-bold">Planet Odysseys</span>
            </div>
            <p class="text-sm text-gray-400 leading-relaxed">
              Authentic Peru travel experiences. Locally based in Cusco, specializing in Lake Titicaca cultural tours and responsible tourism.
            </p>
            <div class="flex items-center space-x-4">
              <a href="https://facebook.com/planetodysseys" target="_blank" rel="noopener" class="text-gray-400 hover:text-white transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
              <a href="https://instagram.com/planetodysseys" target="_blank" rel="noopener" class="text-gray-400 hover:text-white transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073z"/><path d="M12 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
              </a>
              <a href="https://wa.me/51969355221" target="_blank" rel="noopener" class="text-gray-400 hover:text-white transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
              </a>
            </div>
          </div>

          <!-- Quick Links -->
          <div>
            <h3 class="text-sm font-semibold mb-4">Quick Links</h3>
            <ul class="space-y-2 text-sm text-gray-400">
              <li><a href="/destinations" class="hover:text-white transition-colors">Destinations</a></li>
              <li><a href="/tours" class="hover:text-white transition-colors">All Tours</a></li>
              <li><a href="/transfers" class="hover:text-white transition-colors">Transfers</a></li>
              <li><a href="/blog" class="hover:text-white transition-colors">Travel Stories</a></li>
              <li><a href="/about" class="hover:text-white transition-colors">About Us</a></li>
              <li><a href="/contact" class="hover:text-white transition-colors">Contact</a></li>
            </ul>
          </div>

          <!-- Popular Tours -->
          <div>
            <h3 class="text-sm font-semibold mb-4">Popular Tours</h3>
            <ul class="space-y-2 text-sm text-gray-400">
              <li><a href="/tour/uros-floating-islands-of-lake-titicaca-tour" class="hover:text-white transition-colors">Uros Floating Islands</a></li>
              <li><a href="/tour/lake-titicaca-peru-uros-amantani-island-and-taquile-island" class="hover:text-white transition-colors">Amantani Homestay</a></li>
              <li><a href="/tour/route-of-the-sun-cusco-puno-sun-route-cusco" class="hover:text-white transition-colors">Sun Route</a></li>
              <li><a href="/tour/sillustani-peru-half-day-tour" class="hover:text-white transition-colors">Sillustani Tours</a></li>
            </ul>
          </div>

          <!-- Contact Info -->
          <div>
            <h3 class="text-sm font-semibold mb-4">Contact</h3>
            <ul class="space-y-3 text-sm text-gray-400">
              <li class="flex items-start space-x-2">
                <svg class="w-5 h-5 text-accent-blue flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                <a href="tel:+51969355221" class="hover:text-white transition-colors">+51 969 355 221</a>
              </li>
              <li class="flex items-start space-x-2">
                <svg class="w-5 h-5 text-accent-blue flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <a href="mailto:tours@planetodysseys.com" class="hover:text-white transition-colors">tours@planetodysseys.com</a>
              </li>
              <li class="flex items-start space-x-2">
                <svg class="w-5 h-5 text-accent-blue flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span>Jr. Cuba J7-B, Urb. Quispicanchis<br />Cusco 08003, Peru</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- Bottom Bar -->
        <div class="pt-8 border-t border-white/10">
          <div class="flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
            <p class="text-sm text-gray-400">
              © 2026 Planet Odysseys E.I.R.L. | RUC: 2060999824
            </p>
            <div class="flex items-center space-x-6 text-sm text-gray-400">
              <a href="/legal-information" class="hover:text-white transition-colors">Legal</a>
              <a href="/terms-conditions" class="hover:text-white transition-colors">Terms</a>
              <a href="/personal-data-protection" class="hover:text-white transition-colors">Privacy</a>
            </div>
          </div>
        </div>
      </div>
    </footer>

    <script>
      // Mobile menu toggle
      const menuButton = document.getElementById('mobile-menu-button');
      const mobileMenu = document.getElementById('mobile-menu');
      
      menuButton?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
      });

      // Close mobile menu when clicking outside
      document.addEventListener('click', (e) => {
        if (!menuButton?.contains(e.target as Node) && !mobileMenu?.contains(e.target as Node)) {
          mobileMenu?.classList.add('hidden');
        }
      });
    </script>
  </body>
</html>
