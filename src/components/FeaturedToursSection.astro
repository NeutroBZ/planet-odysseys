---
import { getToursByCategory } from '../data/tours';

const featuredTours = getToursByCategory('lake-titicaca');
---

<section class="section-padding">
  <div class="container-custom">

    <!-- HEADER -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-16">
      <div class="max-w-2xl mb-8 md:mb-0">
        <div class="inline-block px-4 py-2 rounded-full glass text-sm font-semibold mb-4">
          Most Popular
        </div>
        <h2 class="text-4xl md:text-5xl font-display font-bold mb-6">
          Featured <span class="gradient-text">Tours</span>
        </h2>
        <p class="text-lg text-white/70">
          Handpicked experiences combining authentic culture, stunning landscapes, and responsible tourism.
        </p>
      </div>
      <a href="/tour" class="btn-premium whitespace-nowrap">
        View All Tours
      </a>
    </div>

    <!-- SWIPER -->
    <div class="swiper featuredSwiper group relative">
      <div class="swiper-wrapper">
        {featuredTours.slice(0, 6).map((tour) => (
          <div class="swiper-slide">
            <a href={`/tour/${tour.slug}`} class="block">
              <article class="glass-strong rounded-2xl overflow-hidden">
                <div class="relative aspect-[4/3] overflow-hidden">
                  <img 
                    src={tour.image} 
                    alt={tour.title}
                    class="w-full h-full object-cover hover:scale-110 transition-transform duration-500"
                    loading="lazy"
                  />
                </div>
                <div class="p-6">
                  <h3 class="text-xl font-bold mb-2 hover:gradient-text transition-all">
                    {tour.shortTitle}
                  </h3>
                  <p class="text-sm text-white/70 mb-4 line-clamp-2">
                    {tour.description}
                  </p>
                  <div class="flex justify-between items-center">
                    <div class="flex items-center gap-1">
                      <span class="text-[#c6a15b]">★</span>
                      <span class="text-sm">{tour.rating}</span>
                      <span class="text-sm text-white/50">({tour.reviews})</span>
                    </div>
                    <span class="text-xl font-bold text-[#c6a15b]">
                      ${tour.price}
                    </span>
                  </div>
                </div>
              </article>
            </a>
          </div>
        ))}
      </div>

      <!-- Botones de navegación -->
      <div class="swiper-button-next !w-8 !h-8 !bg-white/10 hover:!bg-white/20 !backdrop-blur-md rounded-full !text-white opacity-0 group-hover:opacity-100 transition-all after:!text-base"></div>
      <div class="swiper-button-prev !w-8 !h-8 !bg-white/10 hover:!bg-white/20 !backdrop-blur-md rounded-full !text-white opacity-0 group-hover:opacity-100 transition-all after:!text-base"></div>

      <!-- Paginación -->
      <div class="swiper-pagination !relative !bottom-0 mt-8"></div>
    </div>

  </div>
</section>

<script>
  import Swiper from 'swiper';
  import { Navigation, Pagination, Autoplay } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/navigation';
  import 'swiper/css/pagination';

  new Swiper('.featuredSwiper', {
    modules: [Navigation, Pagination, Autoplay],
    slidesPerView: 1,
    spaceBetween: 20,
    autoplay: { delay: 4000 },
    pagination: { el: '.swiper-pagination', clickable: true },
    navigation: {
      nextEl: '.swiper-button-next',
      prevEl: '.swiper-button-prev',
    },
    breakpoints: {
      640: { slidesPerView: 1.5 },
      1024: { slidesPerView: 3 }
    }
  });
</script>