---
// src/components/TransferCard.astro
export interface Props {
  title: string;
  description: string;
  price: string;
  image: string;
  link: string;
}
const { title, description, price, image, link } = Astro.props;
---

<a href={link} class="group block rounded-2xl overflow-hidden shadow-lg card-hover transition-all duration-300">
  <div class="relative w-full h-48 overflow-hidden">
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-black/40"></div>
  </div>
  <div class="p-4 bg-[#001a24]">
    <h3 class="text-xl font-display font-bold text-white mb-1">{title}</h3>
    <p class="text-gray-300 text-sm mb-2">{description}</p>
    <p class="text-accent-blue font-semibold">{price}</p>
  </div>
</a>