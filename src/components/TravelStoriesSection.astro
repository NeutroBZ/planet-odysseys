---
// src/components/TravelStoriesSection.astro
import type { BlogPost } from '../data/blog';

export interface Props {
  featuredBlog: BlogPost[];
}

const { featuredBlog } = Astro.props;

const formatDate = (date: string) => {
  return new Date(date).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  });
};
---

<section class="section-padding">
  <div class="container-custom">
    {/* Header */}
    <div class="text-center mb-12">
      <h2 class="text-4xl md:text-5xl font-display font-bold mb-4">
        Travel <span class="gradient-text">Stories</span>
      </h2>
      <p class="text-xl text-white/70 max-w-2xl mx-auto">
        Inspiring tales and tips from our adventures around Lake Titicaca
      </p>
    </div>

    {/* Grid de posts */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {featuredBlog.map((post) => (
        <a 
          href={`${post.slug}`}
          class="group block glass card-hover rounded-2xl overflow-hidden"
        >
          {/* Imagen */}
          <div class="relative h-56 overflow-hidden bg-dark-200">
            {post.image ? (
              <img 
                src={post.image}
                alt={post.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                loading="lazy"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center">
                <svg class="w-16 h-16 text-white/20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
            )}
            
            {/* Categoría */}
            {post.categories && post.categories.length > 0 && (
              <div class="absolute top-4 left-4">
                <span class="glass-strong px-3 py-1 rounded-full text-xs font-semibold">
                  {post.categories[0]}
                </span>
              </div>
            )}
          </div>

          {/* Contenido */}
          <div class="p-6">
            {/* Fecha */}
            <p class="text-sm text-white/40 mb-2">
              {formatDate(post.date)}
            </p>

            {/* Título */}
            <h3 class="text-xl font-bold mb-3 group-hover:gradient-text transition-all line-clamp-2">
              {post.title}
            </h3>

            {/* Descripción */}
            {post.description && (
              <p class="text-white/70 text-sm mb-4 line-clamp-3">
                {post.description}
              </p>
            )}

            {/* Link */}
            <div class="flex items-center justify-between pt-4 border-t border-white/10">
              <span class="text-sm text-white/40">Read story</span>
              <span class="text-sm text-accent-blue font-semibold group-hover:translate-x-2 transition-transform">
                Read More →
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>

    {/* Botón ver todos */}
    <div class="text-center mt-12">
      <a 
        href="/blog" 
        class="inline-flex items-center gap-2 glass-strong px-8 py-4 rounded-full font-semibold hover:bg-white/10 transition-colors"
      >
        <span>View All Stories</span>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>